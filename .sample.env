# 이 파일을 복사하여 .env.local 로 저장 후 값 입력

# 네이버 지도 클라이언트 ID
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=your_naver_map_client_id_here

# Spring Boot 백엔드 URL (서버 사이드 전용)
# Docker: http://localhost:8080 또는 http://spring-boot-container:8080
SPRING_API_URL=http://localhost:8080

# 관리자 비밀번호 (신랑신부 전용 페이지 /admin 접근 비밀번호)
ADMIN_PASSWORD=test123
# 사이트 URL
NEXT_PUBLIC_SITE_URL=https://your-wedding-invitation-site.com
